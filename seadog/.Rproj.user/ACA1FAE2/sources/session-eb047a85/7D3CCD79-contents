	journal = {Aquatic Toxicology},
	pages = {106799},
	preprint = {https://hal.science/hal-04417025v1},
	publisher = {Elsevier},
	title = {Fish gut and skin microbiota dysbiosis induced by exposure to commercial sunscreen formulations},
	url = {https://www.sciencedirect.com/science/article/abs/pii/S0166445X23004010?dgcid=author},
	volume = {266},
